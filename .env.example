API_PORT=8787
WEB_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
STORAGE_ROOT=./storage
DATABASE_URL=
SERVE_WEB_APP=true
WEB_DIST_DIR=./apps/web/dist
WORKER_POLL_INTERVAL_MS=1000
MEDIA_BASE_URL=
KEEP_ORIGINAL_UPLOADS=false
MAX_COMPRESSION_INPUT_BYTES=1073741824

# Split-service web deploys should set this in apps/web/.env (or Railway web service vars):
# VITE_API_BASE=https://<api-domain>

# Livepeer
LIVEPEER_API_KEY=
LIVEPEER_API_BASE=https://livepeer.studio/api
LIVEPEER_RTMP_INGEST_BASE=rtmp://rtmp.livepeer.com/live
LIVEPEER_DEFAULT_ENABLED=true

# Pinata / IPFS
PINATA_JWT=
PINATA_UPLOAD_URL=https://uploads.pinata.cloud/v3/files
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs
PINATA_NETWORK=public

# External ingest (yt-dlp watchdogs)
EXTERNAL_INGEST_DOWNLOAD_TIMEOUT_MS=1800000
EXTERNAL_INGEST_DOWNLOAD_STALL_TIMEOUT_MS=240000
EXTERNAL_INGEST_EXPAND_TIMEOUT_MS=120000
EXTERNAL_INGEST_EXPAND_STALL_TIMEOUT_MS=45000
