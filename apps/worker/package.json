{
  "name": "@openchannel/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "if [ -n \"$RAILWAY_ENVIRONMENT\" ]; then node dist/worker.js; else tsx watch src/worker.ts; fi",
    "start": "node dist/worker.js",
    "build": "npm run build -w @openchannel/shared && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"No lint configured for worker\""
  },
  "dependencies": {
    "@openchannel/shared": "0.1.0",
    "pg": "^8.20.0",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6"
  }
}
